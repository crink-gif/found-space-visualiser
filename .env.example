# Copy to ".env" for local AI rendering, or set these in the Vercel dashboard.

# REQUIRED for live AI rendering. Free key from https://aistudio.google.com/app/apikey
# Without it, the app runs in DEMO mode (still fully usable).
GEMINI_API_KEY=

# LEADS → HUBSPOT. Private App token from HubSpot:
# Settings → Integrations → Private Apps → Create → scope "crm.objects.contacts.write"
# Each submitted lead becomes/updates a HubSpot contact (deduped by email).
HUBSPOT_TOKEN=

# OPTIONAL. Also send leads to any other webhook (Zapier / Make / Slack / Sheets)
# that accepts a JSON POST. Leave blank to skip.
LEAD_WEBHOOK_URL=

# OPTIONAL. Override the image model if you ever need to.
GEMINI_MODEL=gemini-2.5-flash-image
